{
  "name": "@orqastudio/claude-integration",
  "version": "0.1.0-dev",
  "displayName": "Claude Integration",
  "description": "Claude AI provider — Agent SDK sidecar + Claude Code governance hooks via @orqastudio/claude-code-cli.",
  "requires": [],
  "provides": {
    "schemas": [],
    "views": [],
    "widgets": [],
    "relationships": [],
    "sidecar": {
      "key": "claude-agent",
      "label": "Claude Agent SDK",
      "runtime": "node",
      "entrypoint": "sidecar/dist/sidecar.js",
      "requires": [
        {
          "binary": "node",
          "minVersion": "20.0.0"
        }
      ]
    },
    "hooks": [
      {
        "key": "claude-session-start",
        "event": "session-start",
        "runtime": "system",
        "entrypoint": "node_modules/@orqastudio/claude-code-cli/hooks/scripts/session-start.sh"
      }
    ]
  }
}
